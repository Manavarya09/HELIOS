---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HELIOS - Futuristic AI Command System">
  <main class="relative overflow-hidden min-h-screen">
    <div class="grid-bg"></div>
    
    <!-- Hero Section -->
    <section class="relative z-10 flex flex-col items-center justify-center min-h-screen px-6 text-center">
      <div class="max-w-4xl mx-auto">
        <span class="inline-block px-4 py-1.5 mb-6 text-sm font-mono border rounded-full text-cyan-400 border-cyan-400/30 bg-cyan-400/5">
          v0.8.0 Released
        </span>
        
        <h1 class="text-6xl md:text-7xl font-bold tracking-tight mb-6">
          <span class="text-white">HELIOS</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-gray-400 max-w-2xl mx-auto mb-10">
          A futuristic AI command system built with Rust and egui
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://github.com/Manavarya09/HELIOS" class="px-8 py-3 bg-cyan-500 hover:bg-cyan-400 text-black font-semibold rounded-lg transition-all">
            Get Started
          </a>
          <a href="#features" class="px-8 py-3 border border-gray-700 hover:border-gray-600 text-white rounded-lg transition-all">
            Explore Features
          </a>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="relative z-10 px-6 py-32">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-4xl font-bold text-center text-white mb-16">Features</h2>
        
        <div class="grid md:grid-cols-3 gap-6">
          <div class="p-6 border border-gray-800 rounded-xl bg-gray-900/50 hover:border-cyan-500/50 transition-colors">
            <h3 class="text-xl font-semibold text-white mb-3">AI Integration</h3>
            <p class="text-gray-400">Multi-provider support for Ollama, OpenAI, Anthropic, Claude, Gemini, and DeepSeek</p>
          </div>
          
          <div class="p-6 border border-gray-800 rounded-xl bg-gray-900/50 hover:border-cyan-500/50 transition-colors">
            <h3 class="text-xl font-semibold text-white mb-3">Real-Time Metrics</h3>
            <p class="text-gray-400">CPU, Memory, Network, Power, GPU, and Disk monitoring with live graphs</p>
          </div>
          
          <div class="p-6 border border-gray-800 rounded-xl bg-gray-900/50 hover:border-cyan-500/50 transition-colors">
            <h3 class="text-xl font-semibold text-white mb-3">7 Themes</h3>
            <p class="text-gray-400">Dark, Light, Cyberpunk, Ocean, Forest, Neon, and Matrix themes</p>
          </div>
          
          <div class="p-6 border border-gray-800 rounded-xl bg-gray-900/50 hover:border-cyan-500/50 transition-colors">
            <h3 class="text-xl font-semibold text-white mb-3">Plugin System</h3>
            <p class="text-gray-400">Extensible architecture with hot-reload support</p>
          </div>
          
          <div class="p-6 border border-gray-800 rounded-xl bg-gray-900/50 hover:border-cyan-500/50 transition-colors">
            <h3 class="text-xl font-semibold text-white mb-3">JARVIS Core</h3>
            <p class="text-gray-400">System status with encryption, shield, and integrity monitoring</p>
          </div>
          
          <div class="p-6 border border-gray-800 rounded-xl bg-gray-900/50 hover:border-cyan-500/50 transition-colors">
            <h3 class="text-xl font-semibold text-white mb-3">Voice System</h3>
            <p class="text-gray-400">TTS/STT support with configurable voice</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Code Preview -->
    <section class="relative z-10 px-6 py-24">
      <div class="max-w-4xl mx-auto">
        <div class="rounded-xl border border-gray-800 overflow-hidden">
          <div class="flex items-center px-4 py-3 bg-gray-900 border-b border-gray-800">
            <div class="flex gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
            </div>
            <span class="ml-4 text-sm text-gray-500">terminal</span>
          </div>
          <div class="p-6 bg-black font-mono text-sm overflow-x-auto">
            <div class="text-gray-500">$</div>
            <div class="text-cyan-400">> ai What is Rust?</div>
            <div class="text-gray-400 mt-2">Rust is a systems programming language that focuses on safety,</div>
            <div class="text-gray-400">performance, and concurrency. It provides memory safety</div>
            <div class="text-gray-400">without garbage collection.</div>
            <div class="text-gray-500 mt-3">$</div>
            <div class="text-cyan-400">> stats</div>
            <div class="flex gap-8 mt-2">
              <div><span class="text-gray-500">CPU</span> <span class="text-white">23%</span></div>
              <div><span class="text-gray-500">MEM</span> <span class="text-white">8.2GB</span></div>
              <div><span class="text-gray-500">GPU</span> <span class="text-white">45%</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="relative z-10 px-6 py-12 border-t border-gray-800">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-gray-500">
          HELIOS - Built with Rust and egui
        </p>
        <div class="mt-4 flex justify-center gap-6">
          <a href="https://github.com/Manavarya09/HELIOS" class="text-gray-400 hover:text-white transition-colors">GitHub</a>
          <a href="https://github.com/Manavarya09/HELIOS/issues" class="text-gray-400 hover:text-white transition-colors">Issues</a>
          <a href="https://github.com/Manavarya09/HELIOS/discussions" class="text-gray-400 hover:text-white transition-colors">Discussions</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style is:global>
  * {
    box-sizing: border-box;
  }
  
  html {
    scroll-behavior: smooth;
  }
  
  body {
    @apply bg-black text-white antialiased;
    font-family: system-ui, -apple-system, sans-serif;
  }
  
  .grid-bg {
    position: fixed;
    inset: 0;
    background-image: 
      linear-gradient(rgba(6, 182, 212, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(6, 182, 212, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    pointer-events: none;
  }
</style>